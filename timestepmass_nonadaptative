import math
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

G=6.67e-11
c=3e8
hbar=1.055e-34
k=1.381e-23
sigma=5.670e-8

def radius (M):
  #calculates radius from mass
  return 2 * G * M / c**2

def temperature (M):
  #gives Hawking temperature from mass
  return hbar * c**3 / (8 * 3.14159 * G * M * k)

def power(M):
  #calculates the total power radiated from the mass
  r_s = radius(M)
  A = 4 * 3.14159 * r_s**2
  T = temperature (M)
  return sigma * A * T**4

def step(n, M, dt, time_elapsed, history=None):
    #advances n steps forward and then returns the updated mass
    if history is None:
        history = []
    for i in range(n):
        P = power(M)
        dM = (P * dt) / c**2
        if dM > M:
            print("Mass reached 0", i)
            history.append([time_elapsed, 0])
            M = 0
            break
        M = M -dM
        time_elapsed += dt
        history.append([time_elapsed, M])
    return M, time_elapsed, history

#manual run
M = 1e6
dt = 1
time_elapsed = 0
history=[]

M, time_elapsed, history = step(1000, M, dt, time_elapsed, history)
print("Mass after 1000 time steps:", M)
print("Time elapsed so far:", time_elapsed)


#plotting - shows whatvever has been calculated so far

df=pd.DataFrame(history, columns=["Time (s)", "Mass (kg)"])

df.plot(x="Time (s)", y="Mass (kg)", logy=True, grid=True)
